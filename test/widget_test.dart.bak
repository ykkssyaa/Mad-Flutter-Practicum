// This is a basic Flutter widget test.
//
// To perform an interaction with a widget in your test, use the WidgetTester
// utility in the flutter_test package. For example, you can send tap and scroll
// gestures. You can also use WidgetTester to find child widgets in the widget
// tree, read text, and verify that the values of widget properties are correct.

import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';

import 'package:mad_flutter_practicum/main.dart';

void main() {
  testWidgets('App launches smoke test', (WidgetTester tester) async {
    // Build our app and trigger a frame.
    await tester.pumpWidget(const RootApp());
    await tester.pumpAndSettle();

    // Verify that the app starts and shows the home screen
    // Check that MaterialApp is present
    expect(find.byType(MaterialApp), findsOneWidget);

    // Verify bottom navigation exists (part of HomePage after login)
    // For now, just verify that app launched without crashing
  });
}
